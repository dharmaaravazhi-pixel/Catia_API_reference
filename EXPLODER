Function CheckSceneExists(prodDoc As Object, sceneName As String, ByRef finalSceneName As String, ByRef sceneExistsChoice As VbMsgBoxResult) As Boolean
    CheckSceneExists = False
    Dim rootProd As Object: Set rootProd = prodDoc.Product
    Dim scenes As Object: Set scenes = rootProd.GetTechnologicalObject("ScenesCollection")

    Dim i As Integer, sc As Object, sceneExists As Boolean
    sceneExists = False
    For i = 1 To scenes.count
        Set sc = scenes.Item(i)
        If Not sc Is Nothing Then
            If StrComp(sc.Name, sceneName, vbTextCompare) = 0 Then
                sceneExists = True
                Exit For
            End If
        End If
    Next

    finalSceneName = sceneName
    sceneExistsChoice = vbYes
    If sceneExists Then
        sceneExistsChoice = MsgBox("The scene '" & sceneName & "' already exists." & vbCrLf & vbCrLf & _
                            "Click 'Yes' to OVERWRITE the existing scene." & vbCrLf & _
                            "Click 'No' to CREATE a new scene.", vbYesNoCancel + vbQuestion, "Scene Exists")
        If sceneExistsChoice = vbNo Then
            finalSceneName = GetUniqueProductSceneName(scenes, sceneName)
        ElseIf sceneExistsChoice = vbCancel Then
            Exit Function
        End If
    End If
    CheckSceneExists = True
End Function

Function CreateSceneFromCurrentState(prodDoc As Object, sceneName As String, finalSceneName As String, sceneExistsChoice As VbMsgBoxResult) As Object
    On Error GoTo Failed
    Set CreateSceneFromCurrentState = Nothing
    
    Dim rootProd As Object: Set rootProd = prodDoc.Product
    Dim scenes As Object: Set scenes = rootProd.GetTechnologicalObject("ScenesCollection")

    If sceneExistsChoice = vbYes Then
        Dim i As Integer, sc As Object, existingScene As Object
        For i = 1 To scenes.count
            Set sc = scenes.Item(i)
            If Not sc Is Nothing Then
                If StrComp(sc.Name, sceneName, vbTextCompare) = 0 Then
                    Set existingScene = sc
                    Exit For
                End If
            End If
        Next
        If Not existingScene Is Nothing Then
            Dim sel As Object: Set sel = prodDoc.Selection
            sel.Clear: sel.Add existingScene: sel.Delete: sel.Clear
        End If
    End If

    Dim prodArray(0) As Variant
    Set prodArray(0) = rootProd
    Dim newScene As Object
    Set newScene = scenes.AddProductSceneFull(finalSceneName, prodArray)
    Set CreateSceneFromCurrentState = newScene
    Exit Function
Failed:
    MsgBox "Failed to create scene.", vbCritical
End Function

Function GetUniqueProductSceneName(scenes As Object, baseName As String) As String
    Dim candidate As String, suffix As Integer
    candidate = baseName: suffix = 2
    Do While ProductSceneNameExists(scenes, candidate)
        candidate = baseName & "_" & CStr(suffix)
        suffix = suffix + 1
    Loop
    GetUniqueProductSceneName = candidate
End Function

Function ProductSceneNameExists(scenes As Object, sceneName As String) As Boolean
    On Error Resume Next
    ProductSceneNameExists = False
    Dim i As Integer, sc As Object
    For i = 1 To scenes.count
        Set sc = scenes.Item(i)
        If Err.Number = 0 And Not sc Is Nothing Then
            If StrComp(CStr(sc.Name), sceneName, vbTextCompare) = 0 Then
                ProductSceneNameExists = True
                On Error GoTo 0: Exit Function
            End If
        End If
        Err.Clear
    Next
    On Error GoTo 0
End Function

Function IsProductDocumentReady(doc As Object) As Boolean
    On Error Resume Next
    IsProductDocumentReady = False
    If doc Is Nothing Then Exit Function
    If TypeName(doc) <> "ProductDocument" Then Exit Function
    Dim rootProd As Object: Set rootProd = doc.Product
    If Err.Number <> 0 Or rootProd Is Nothing Then Err.Clear: Exit Function
    Dim sel As Object: Set sel = doc.Selection
    If Err.Number <> 0 Or sel Is Nothing Then Err.Clear: Exit Function
    IsProductDocumentReady = True
    On Error GoTo 0
End Function

Function IsValidDirection(dirText As String) As Boolean
    Select Case UCase(dirText)
        Case "X", "-X", "Y", "-Y", "Z", "-Z": IsValidDirection = True
        Case Else: IsValidDirection = False
    End Select
End Function

Function AxisLetter(dirText As String) As String
    dirText = UCase(dirText)
    If Left(dirText, 1) = "-" Then AxisLetter = Mid(dirText, 2, 1) Else AxisLetter = Left(dirText, 1)
End Function

Function IsProductInactive(oProd As Object) As Boolean
    On Error Resume Next
    IsProductInactive = CBool(oProd.IsInactive)
    If Err.Number = 0 Then If IsProductInactive Then On Error GoTo 0: Exit Function Else Err.Clear
    IsProductInactive = CBool(oProd.Inactive)
    If Err.Number = 0 Then If IsProductInactive Then On Error GoTo 0: Exit Function Else Err.Clear
    
    Dim hasShape As Boolean: hasShape = CBool(oProd.HasAMasterShapeRepresentation)
    If Err.Number = 0 Then If hasShape = False Then IsProductInactive = True: On Error GoTo 0: Exit Function Else Err.Clear
    
    hasShape = CBool(oProd.ReferenceProduct.HasAMasterShapeRepresentation)
    If Err.Number = 0 Then If hasShape = False Then IsProductInactive = True: On Error GoTo 0: Exit Function Else Err.Clear
    
    Dim shapeRep As Object: Set shapeRep = oProd.GetMasterShapeRepresentation(False)
    If Err.Number = 0 Then If shapeRep Is Nothing Then IsProductInactive = True: On Error GoTo 0: Exit Function Else Err.Clear
    
    Dim activeShapeName As String: activeShapeName = CStr(oProd.GetActiveShapeName)
    If Err.Number = 0 Then If Len(activeShapeName) = 0 Then IsProductInactive = True: On Error GoTo 0: Exit Function Else Err.Clear
    
    IsProductInactive = CBool(oProd.Activity = False)
    If Err.Number = 0 Then If IsProductInactive Then On Error GoTo 0: Exit Function Else Err.Clear
    
    Dim showState As Integer: showState = 0
    CATIA.ActiveDocument.Selection.Clear: CATIA.ActiveDocument.Selection.Add oProd
    CATIA.ActiveDocument.Selection.VisProperties.GetShow showState
    CATIA.ActiveDocument.Selection.Clear
    If Err.Number = 0 Then If showState <> 0 Then IsProductInactive = True: On Error GoTo 0: Exit Function Else Err.Clear
    
    IsProductInactive = False
    On Error GoTo 0
End Function

Function IsObjectInactive(oObj As Object) As Boolean
    On Error Resume Next
    IsObjectInactive = CBool(oObj.IsInactive)
    If Err.Number = 0 Then If IsObjectInactive Then On Error GoTo 0: Exit Function Else Err.Clear
    IsObjectInactive = CBool(oObj.Inactive)
    If Err.Number = 0 Then If IsObjectInactive Then On Error GoTo 0: Exit Function Else Err.Clear
    IsObjectInactive = CBool(oObj.Activity = False)
    If Err.Number = 0 Then If IsObjectInactive Then On Error GoTo 0: Exit Function Else Err.Clear
    IsObjectInactive = False
    On Error GoTo 0
End Function
